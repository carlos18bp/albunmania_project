{
  "name": "albunmania-frontend",
  "version": "0.1.0",
  "description": "PWA de intercambio de cromos del Mundial 26 — Albunmanía (Cliente: ProjectApp)",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--no-deprecation next dev",
    "build": "NODE_OPTIONS=--no-deprecation next build",
    "start": "NODE_OPTIONS=--no-deprecation next start",
    "lint": "eslint",
    "test": "NODE_OPTIONS=--no-deprecation jest",
    "test:watch": "NODE_OPTIONS=--no-deprecation jest --watch",
    "test:ci": "NODE_OPTIONS=--no-deprecation jest --ci",
    "test:coverage": "NODE_OPTIONS=--no-deprecation jest --coverage && node scripts/coverage-summary.cjs",
    "e2e:clean": "rm -rf playwright-report test-results blob-report",
    "e2e:modules": "npm run e2e:clean && node ./scripts/e2e-modules.cjs",
    "e2e:module": "npm run e2e:clean && node ./scripts/e2e-module.cjs",
    "e2e:coverage": "npm run e2e:clean && npm run test:e2e",
    "e2e:coverage:module": "npm run e2e:clean && node ./scripts/e2e-coverage-module.cjs",
    "e2e": "playwright test",
    "e2e:desktop": "playwright test --project=\"Desktop Chrome\"",
    "e2e:mobile": "playwright test --project=\"Mobile Chrome\"",
    "e2e:tablet": "playwright test --project=\"Tablet\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:coverage && npm run test:e2e"
  },
  "dependencies": {
    "@hcaptcha/react-hcaptcha": "^1.11.0",
    "@react-oauth/google": "^0.13.5",
    "@zxing/browser": "^0.1.5",
    "axios": "^1.15.2",
    "fuse.js": "^7.3.0",
    "js-cookie": "^3.0.5",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-leaflet": "^4.2.1",
    "web-push": "^3.6.7",
    "zod": "^3.23.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-playwright": "^2.10.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5"
  },
  "overrides": {
    "minimatch": "^10.2.4",
    "flatted": "^3.4.0"
  }
}
