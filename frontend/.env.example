# =============================================================================
# Google OAuth Configuration
# =============================================================================
# ⚠️  TODO: regenerate in Google Cloud Console for the Albunmanía project.
# The previous value belonged to the base template's OAuth project — do NOT use it.
# Get your client ID from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=<TODO: regenerate in GCP for Albunmanía>

# =============================================================================
# hCaptcha (frontend sitekey only; secret stays in backend)
# =============================================================================
NEXT_PUBLIC_HCAPTCHA_SITEKEY=<TODO: get from hcaptcha.com>

# =============================================================================
# Web Push (VAPID public key shared with backend)
# =============================================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<TODO: generate with py-vapid; same key as VAPID_PUBLIC_KEY in backend/.env>

# =============================================================================
# API Configuration (optional - defaults to /api which uses Next.js rewrites)
# =============================================================================
NEXT_PUBLIC_API_BASE_URL=/api

# Django backend origin used by Next.js rewrites and media proxy
NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:8000
