# Albunmanía staging — frontend environment template.
# Copy to frontend/.env.production on the VPS, fill the <<placeholders>>,
# then run `npm ci && npm run build` from the frontend dir.
#
# `NEXT_PUBLIC_*` values are inlined into the client bundle at build
# time — never put secrets here. They are visible in the browser source.

# ── API origin ─────────────────────────────────────────────────
# Frontend and backend live on the same origin behind nginx, so the
# default /api rewrite is the right choice.
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_BACKEND_ORIGIN=https://albunmania.projectapp.co

# ── Google OAuth (browser-side client id, not secret) ─────────
# Same value as GOOGLE_OAUTH_CLIENT_ID in backend/.env.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=<<google_oauth_client_id>>

# ── hCaptcha sitekey (public) ─────────────────────────────────
# Same value as DJANGO_HCAPTCHA_SITEKEY in backend/.env.
NEXT_PUBLIC_HCAPTCHA_SITEKEY=<<hcaptcha_site_key>>

# ── VAPID public key for Web Push subscribe() ─────────────────
# Same value as VAPID_PUBLIC_KEY in backend/.env. Must match exactly
# (URL-safe base64, no padding) or the browser refuses to subscribe.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<<vapid_public_key_b64url>>

# ── Sentry browser DSN (optional) ─────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://<<key>>@o<<org>>.ingest.sentry.io/<<project>>
