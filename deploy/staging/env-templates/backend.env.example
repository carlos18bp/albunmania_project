# Albunmanía staging — backend environment template.
# Copy to backend/.env on the VPS and fill the <<placeholders>>.
# `chmod 600 backend/.env` to keep secrets out of group/world reach.

# ── Django core ────────────────────────────────────────────────
DJANGO_ENV=production
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=<<replace_with_64_char_token_urlsafe>>
DJANGO_ALLOWED_HOSTS=albunmania.projectapp.co,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# CSRF + CORS — frontend lives on the same origin, but list explicitly.
DJANGO_CSRF_TRUSTED_ORIGINS=https://albunmania.projectapp.co
DJANGO_CORS_ALLOWED_ORIGINS=https://albunmania.projectapp.co

# ── Database (MySQL on localhost) ──────────────────────────────
DATABASE_URL=mysql://albunmania_staging:<<MYSQL_PASSWORD>>@127.0.0.1:3306/albunmania_staging?charset=utf8mb4

# ── Auth: Google OAuth ────────────────────────────────────────
# REGENERATE in Google Cloud Console — DO NOT reuse the template's value.
# Authorized origins:    https://albunmania.projectapp.co
# Authorized redirects:  https://albunmania.projectapp.co/sign-in
GOOGLE_OAUTH_CLIENT_ID=<<google_oauth_client_id>>
GOOGLE_OAUTH_CLIENT_SECRET=<<google_oauth_client_secret>>

# ── Auth: hCaptcha ────────────────────────────────────────────
# Get keys from https://dashboard.hcaptcha.com → site for albunmania.projectapp.co.
DJANGO_HCAPTCHA_SITEKEY=<<hcaptcha_site_key>>
DJANGO_HCAPTCHA_SECRET=<<hcaptcha_secret>>

# ── Web Push (VAPID) ──────────────────────────────────────────
# Generate with `vapid --gen` (py_vapid). Both halves are URL-safe base64.
# The PUBLIC key MUST also live in frontend/.env.production as
# NEXT_PUBLIC_VAPID_PUBLIC_KEY — it is shared with the browser.
VAPID_PUBLIC_KEY=<<vapid_public_key_b64url>>
VAPID_PRIVATE_KEY=<<vapid_private_key_b64url>>
VAPID_CLAIMS_EMAIL=admin@albunmania.co

# ── Email (transactional) ─────────────────────────────────────
# Mirror the fleet convention. Replace with project-specific creds in V1.5.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=<<smtp_user>>
DJANGO_EMAIL_HOST_PASSWORD=<<smtp_app_password>>
DJANGO_EMAIL_USE_TLS=true
DJANGO_DEFAULT_FROM_EMAIL=Albunmanía <noreply@albunmania.projectapp.co>

# ── Redis (Huey broker, sessions cache) ───────────────────────
REDIS_URL=redis://127.0.0.1:6379/3

# ── Sentry (optional, recommended for staging) ────────────────
# SENTRY_DSN=https://<<key>>@o<<org>>.ingest.sentry.io/<<project>>

# ── WhatsApp deep link base ───────────────────────────────────
# Default is fine; override only if a partner-branded short link is set up.
WHATSAPP_DEEP_LINK_BASE=https://wa.me/

# ── IP geolocation (GeoIP2 / MaxMind) ────────────────────────
# Absolute path to a GeoLite2-City.mmdb. The DB is NOT in the repo (MaxMind
# licence + ~60 MB). Sign up for a free MaxMind account, download GeoLite2-City,
# drop the .mmdb on the server (e.g. /home/ryzepeck/webapps/albunmania_staging/geoip/GeoLite2-City.mmdb)
# and point this at it. Leave empty to disable IP geolocation (degrades gracefully).
DJANGO_GEOIP_PATH=
