# =============================================================================
# Environment
# =============================================================================
DJANGO_ENV=development
DJANGO_SECRET_KEY=change-me-replace-with-strong-secret-min-50-chars
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_LOG_LEVEL=INFO

# =============================================================================
# CORS / CSRF
# =============================================================================
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:5173,http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:5173,http://localhost:5173

# =============================================================================
# Database
# =============================================================================
# Development (SQLite — zero config)
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3

# Production (MySQL — uncomment and fill)
# DJANGO_DB_ENGINE=django.db.backends.mysql
# DB_NAME=your_db_name
# DB_USER=replace
# DB_PASSWORD=replace
# DB_HOST=localhost
# DB_PORT=3306

# =============================================================================
# JWT
# =============================================================================
DJANGO_JWT_ACCESS_MINUTES=15
DJANGO_JWT_REFRESH_DAYS=7

# =============================================================================
# Email SMTP
# =============================================================================
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_DEFAULT_FROM_EMAIL=

# =============================================================================
# Google OAuth
# =============================================================================
# ⚠️  TODO: regenerate in Google Cloud Console for the Albunmanía project.
# The previous value belonged to the base template's OAuth project — do NOT use it.
# 1. Console: https://console.cloud.google.com/apis/credentials
# 2. Create "Web application" credentials.
# 3. Register redirect URIs (dev: http://localhost:3000/api/auth/callback/google).
# 4. Paste the Client ID below and the Client Secret in DJANGO_GOOGLE_CLIENT_SECRET.
DJANGO_GOOGLE_CLIENT_ID=<TODO: regenerate in GCP for Albunmanía>
DJANGO_GOOGLE_CLIENT_SECRET=<TODO: regenerate in GCP for Albunmanía>

# =============================================================================
# hCaptcha (anti-bot before Google OAuth callback)
# =============================================================================
# Sign up at https://www.hcaptcha.com/ and get sitekey + secret.
DJANGO_HCAPTCHA_SITEKEY=<TODO: get from hcaptcha.com>
DJANGO_HCAPTCHA_SECRET=<TODO: get from hcaptcha.com>

# =============================================================================
# Web Push (W3C standard, no Firebase)
# =============================================================================
# Generate locally: vapid --gen  (from py-vapid package)
# Public key is also exposed to the frontend as NEXT_PUBLIC_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=<TODO: generate with py-vapid>
VAPID_PRIVATE_KEY=<TODO: generate with py-vapid; keep secret>
VAPID_CONTACT_EMAIL=mailto:contacto@albunmania.co

# =============================================================================
# WhatsApp deep links
# =============================================================================
WHATSAPP_DEEP_LINK_BASE=https://wa.me/

# =============================================================================
# MaxMind GeoIP2 (optional — needed by IP-based geolocation in match engine)
# =============================================================================
# Download GeoLite2-City.mmdb from https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
# and place it under the path below.
MAXMIND_GEOIP2_DB_PATH=/var/lib/maxmind/GeoLite2-City.mmdb

# =============================================================================
# Frontend
# =============================================================================
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Redis (for Huey task queue)
# =============================================================================
REDIS_URL=redis://localhost:6379/1

# =============================================================================
# Backups (django-dbbackup)
# =============================================================================
BACKUP_STORAGE_PATH=/var/backups/albunmania_project
# Retention is controlled by DBBACKUP_CLEANUP_KEEP in settings.py (default: 4 weekly backups ≈ 1 month)

# =============================================================================
# Query Profiling (django-silk)
# =============================================================================
ENABLE_SILK=false
# SLOW_QUERY_THRESHOLD_MS=500
# N_PLUS_ONE_THRESHOLD=10

# =============================================================================
# Legacy API Keys (template residue — pending migration in Epic 1)
# =============================================================================
# The template wired reCAPTCHA; Albunmanía will switch to hCaptcha (see
# DJANGO_HCAPTCHA_* above). These are kept temporarily so the captcha view
# still imports cleanly until Epic 1 swaps the backend.
# When both keys are empty, captcha verification is bypassed (development).
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
